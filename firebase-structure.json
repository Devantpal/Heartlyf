  "_firebase_rules": {
    "_comment": "Place these in Firebase Console → Realtime Database → Rules",
    "rules": {
      ".read": "auth != null",
      ".write": "auth != null",
      "users": {
        "$uid": {
          ".read": "auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'doctor' || root.child('users').child(auth.uid).child('role').val() === 'researcher'",
          ".write": "auth.uid === $uid"
        }
      },
      "devices": {
        ".read": "auth != null",
        ".write": "auth != null"
      },
      "vitals": {
        ".read": "auth != null",
        ".write": "auth != null"
      },
      "ecg_data": {
        ".read": "auth != null",
        ".write": "auth != null"
      },
      "ml_prediction": {
        ".read": "auth != null",
        ".write": "auth != null"
      },
      "alerts": {
        ".read": "auth != null",
        ".write": "auth != null"
      },
      "gps_tracking": {
        ".read": "auth != null",
        ".write": "auth != null"
      },
      "telegram_alerts": {
        ".read": "auth != null",
        ".write": "auth != null"
      },
      "settings": {
        ".read": "auth != null",
        ".write": "auth != null"
      },
      "logs": {
        ".read": "root.child('users').child(auth.uid).child('role').val() === 'doctor' || root.child('users').child(auth.uid).child('role').val() === 'researcher'",
        ".write": "auth != null"
      }
    }
  }
